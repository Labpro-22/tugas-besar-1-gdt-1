@startuml CardOverview
title Overview Card & Deck

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classFontStyle Bold
skinparam classAttributeFontSize 12

enum ChanceType {
    GO_TO_NEAREST_STATION
    MOVE_BACK_3
    GO_TO_JAIL
}

enum CommunityType {
    BIRTHDAY
    DOCTOR_FEE
    CAMPAIGN_FEE
}

enum CardCategory {
    CHANCE
    COMMUNITY
    SKILL
}

abstract class Card {
    # description : string
    --
    + getDescription() : string
    + {abstract} getCardName() : string
    + {abstract} getCategory() : CardCategory
    + {abstract} execute(player : Player&, game : Game&) : void
    + {abstract} clone() : Card*
}

abstract class ActionCard {
    --
    + {abstract} getCategory() : CardCategory
    + {abstract} execute(player : Player&, game : Game&) : void
}

abstract class SkillCard {
    # remainingUses : int
    --
    + getCategory() : CardCategory
    + {abstract} execute(player : Player&, game : Game&) : void
    + isUsable() : bool
}

class CardDeck<T> {
    - drawPile : vector<T*>
    - discardPile : vector<T*>
    --
    + draw() : T*
    + discard(card : T*) : void
    + shuffle() : void
    + reshuffleIfEmpty() : void
    + isEmpty() : bool
    + size() : int
}

package "Action Card" {
    class ChanceCard {
        - type : ChanceType
        --
        + getCardName() : string
        + getCategory() : CardCategory
        + execute(player : Player&, game : Game&) : void
    }

    class CommunityChestCard {
        - type : CommunityType
        --
        + getCardName() : string
        + getCategory() : CardCategory
        + execute(player : Player&, game : Game&) : void
    }
}

package "Skill Card" {
    class MoveCard {
        - steps : int
        --
        + getCardName() : string
        + execute(player : Player&, game : Game&) : void
        + getSteps() : int
    }

    class DiscountCard {
        - discountPercent : int
        - duration : int
        --
        + getCardName() : string
        + execute(player : Player&, game : Game&) : void
        + getDiscount() : int
        + decrementDuration() : void
    }

    class ShieldCard {
        - duration : int
        --
        + getCardName() : string
        + execute(player : Player&, game : Game&) : void
        + decrementDuration() : void
    }

    class TeleportCard {
        --
        + getCardName() : string
        + execute(player : Player&, game : Game&) : void
    }

    class LassoCard {
        --
        + getCardName() : string
        + execute(player : Player&, game : Game&) : void
    }

    class DemolitionCard {
        --
        + getCardName() : string
        + execute(player : Player&, game : Game&) : void
    }
}

Card <|-- ActionCard
Card <|-- SkillCard
ActionCard <|-- ChanceCard
ActionCard <|-- CommunityChestCard
SkillCard <|-- MoveCard
SkillCard <|-- DiscountCard
SkillCard <|-- ShieldCard
SkillCard <|-- TeleportCard
SkillCard <|-- LassoCard
SkillCard <|-- DemolitionCard

CardDeck "1" o-- "0..*" Card : aggregates

ChanceCard ..> ChanceType : uses
CommunityChestCard ..> CommunityType : uses
Card ..> CardCategory : uses

@enduml