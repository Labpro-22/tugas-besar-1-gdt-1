  --
  + render() : void
  + onHover() : void
  + onClicked() : void
}

class SkillCardView {
  -skillCard : SkillCard&
  --
  + onHover() : void
  + onClicked() : void
}

class DiceView {
  -dice : DiceManager&
  --
  + render() : void
  + onHover() : void
  + onClicked() : void
}

class PlayerProfileView {
