  --
  + render() : void
}

class RailroadActView {
  -railroad : RailroadProperty&
  --
  + render() : void
}

class UtilityActView {
  -Utility : UtilityProperty&
  --
  + render() : void
}

class CardDeckView<T> {
  -cardDeck : CardDeck<T>
  --
  + render() : 
  + onHover() : void
  + onClicked() : void
}

class CardView {
  -card : Card&
  -cardBGImgPath : string
