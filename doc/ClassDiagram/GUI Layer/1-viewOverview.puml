@startuml Overview
title View

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classFontStyle Bold
skinparam classAttributeFontSize 12

skinparam groupInheritance 2

class View {
  #x : int
  #y : int
  #scale : float
  #visible : bool
  #interactable : bool
  #renderFunc : auto
  --
  +getX() : int
  +getY() : int
  +getScale() : float
  +isVisible() : bool
  +isInteractable() : bool
  +movePosition(x : int, y : int) : void
  +movePositionDelta(dx : int, dy : int) : void
  +setScale(scale : float) : void
  +setVisibility(visible : bool) : void
  +setRender(render : auto) : void
  +render() : void
}

class Interactable {
  #boundingBox : int[4]
  #active : bool
  #draggable : bool
  #gameCommand : CommandProcessor*
  #onHoverFunc : auto
  #onClickedFunc : auto
  --
  + isActive() : bool
  + isDraggable() : bool
  + isInBoundingBox(x : int, y : int) : bool
  + getGameCommand() : CommandProcessor*
  + getBoundingBox() : int[4]
  + setActive(active : bool) : void
  + setDraggable(draggable : bool) : void
  + setGameCommand() : void
  + setOnHover(onClicked : auto) : void
  + setOnClicked(onClicked : auto) : void
  + moveOnDragged() : void
  + onHover() : void
  + onClicked() : void
}

class Entry {
  -defaultText : string
  -entryText : string
  -onEnterFunc : auto
  --
  + isActive() : bool
  + getEntryText() : string
  + setDefaultText(default : string) : void
  + setEntryText(text : string) : void
  + setOnEnter(onEnter : auto) : void
  + onEnter() : void
}

abstract Popup {
}

class IndefinitePopup {
  #exitButton : Interactable
}

class TimedPopup {
  #popupDuration : int
}

class TilePopupView {
  -player : Player&
  -tile : Tile&
  --
  + renderTilePopupBase() : void()
  + render() : void()
}

class TaxTilePopupView {
  -taxTile : TaxTile&
  --
  + render() : void()
}

class GoTilePopupView {
  -goTile : GoTile&
  --
  + render() : void()
}

class ExceptionPopupView {
  -exceptionType : GameException&
  --
  +render() : void
}

class BoardView {
  -board : Board&
  -tileViews : vector<TileView&>
  --
  + render() : void
}

abstract TileView {
  #tile : Tile&
  #tileType : string
  #tileImagePath : string
  --
  # renderTileBase() : void
}

class MoneyTileView {
  -moneyAmount : int
  --
  + render() : void
}

class PropertyTileView {
  -property : Property&
  --
  # renderPropertyTileBase() : void
  + render () : void
  + onHover() : void
  + onClicked() : void
}

class StreetTileView {
  -street : StreetProperty&
  --
  + render() : void
}

abstract PropertyActView {
  #property : Property&
  #inInventory : bool
  #mortgageButton : Interactable
  --
  + onHover() : void
  # renderActBase() : void
}

class StreetActView {
  -street : StreetProperty&
